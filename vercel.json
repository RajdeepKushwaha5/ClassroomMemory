{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://classroom-memory-api.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/style.css",
      "destination": "/frontend/style.css"
    },
    {
      "source": "/app.js",
      "destination": "/frontend/app.js"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ]
}
