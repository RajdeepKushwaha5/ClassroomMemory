# Classroom Memory: copy to .env and fill in. NEVER commit .env.

# demo (deterministic, zero network) | cloud (real Cognee Cloud)
CLASSROOM_MODE=demo

# From platform.cognee.ai console (Track B Day 1: user signup with code COGNEE-35):
COGNEE_CLOUD_URL=
COGNEE_CLOUD_API_KEY=

# NOTE: Track B needs NO client-side LLM key. recall() answers are generated
# server-side by Cognee Cloud, and quiz questions are curated in curriculum/*.json
# (deterministic by design so the demo cannot die on a quota error).
